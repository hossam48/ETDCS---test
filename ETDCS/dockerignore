# =============================================================================
# .dockerignore - ETDCS Docker Build Exclusions
# Task 14 - Docker Deployment
# =============================================================================
# Prevents unnecessary files from being copied into the Docker image
# Reduces build context size and speeds up builds
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env.local

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.secret
*.key
*.pem

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md
README*
CHANGELOG*
CONTRIBUTING*
LICENSE*
docs/

# -----------------------------------------------------------------------------
# Docker (prevent recursive copy)
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.azure-pipelines/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test_*.py
*_test.py
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Temporary & Quarantine Files
# -----------------------------------------------------------------------------
uploads/quarantine/
*.tmp
*.temp
*.log
*.bak
*.backup

# -----------------------------------------------------------------------------
# Development Database (don't copy dev data into image)
# -----------------------------------------------------------------------------
database/*.db
database/*.sqlite
database/*.sqlite3
*.db-journal
*.db-wal

# -----------------------------------------------------------------------------
# Local Data (should be volume-mounted, not in image)
# -----------------------------------------------------------------------------
files/
uploads/
!uploads/.gitkeep

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.zip
*.tar.gz
*.rar

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.editorconfig
.pre-commit-config.yaml
Makefile
